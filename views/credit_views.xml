<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_credit_recharge_form" model="ir.ui.view">
        <field name="name">credit.recharge.form</field>
        <field name="model">travel.credit.recharge</field>
        <field name="arch" type="xml">
            <form string="Recharger Crédit">
                <group>
                    <field name="member_id" readonly="1"/>
                    <field name="amount" placeholder="Montant en €"/>
                </group>
                <footer>
                    <button name="action_recharge" type="object" string="Recharger" class="btn-primary"/>
                    <button string="Annuler" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <!-- Vue Formulaire Historique Crédit Simplifiée -->
    <record id="view_travel_credit_history_form" model="ir.ui.view">
        <field name="name">travel.credit.history.form</field>
        <field name="model">travel.credit.history</field>
        <field name="arch" type="xml">
            <form string="Historique Crédit">
                <sheet>
                    <group>
                        <group>
                            <field name="date"/>
                            <field name="type"/>
                        </group>
                        <group>
                            <field name="member_id"/>
                            <field name="amount"/>
                            <field name="reservation_id"/>
                        </group>
                    </group>
                    <group>
                        <field name="note"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
</odoo>