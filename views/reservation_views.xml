<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Action pour ouvrir les réservations -->
    <record id="action_reservation" model="ir.actions.act_window">
        <field name="name">Réservations</field>
        <field name="res_model">travel.reservation</field>
        <field name="view_mode">tree,kanban,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Créer une nouvelle réservation
            </p>
            <p>
                Gérez les réservations de vos clients pour les voyages avec suivi des paiements.
            </p>
        </field>
    </record>
    
    <!-- Vue Liste Réservations -->
    <record id="view_reservation_tree" model="ir.ui.view">
        <field name="name">reservation.tree</field>
        <field name="model">travel.reservation</field>
        <field name="arch" type="xml">
            <tree string="Réservations" 
                  decoration-success="status == 'confirmed'" 
                  decoration-info="status == 'done'" 
                  decoration-muted="status == 'cancel'"
                  decoration-warning="remaining_to_pay > 0 and status == 'confirmed'">
                <field name="name" string="Référence"/>
                <field name="create_date" string="Date Création" widget="datetime" optional="show"/>
                <field name="member_id" string="Client"/>
                <field name="company_id" string="Société"/>
                <field name="destination_id" string="Voyage"/>
                <field name="trip_type" string="Type" widget="badge" optional="hide"/>
                <field name="check_in" string="Arrivée"/>
                <field name="check_out" string="Départ"/>
                <field name="purchase_amount" string="Achat" widget="monetary" sum="Total"/>
                <field name="total_price" string="Total" widget="monetary" sum="Total" decoration-bf="True"/>
                <field name="credit_used" string="Crédit" widget="monetary" optional="show"/>
                <field name="credit_refund_amount" string="Avoir" widget="monetary" optional="show"/>
                <field name="remaining_to_pay" string="Reste" widget="monetary" 
                       decoration-danger="remaining_to_pay > 0"/>
                <field name="status" string="État" widget="badge" optional="show"/>
            </tree>
        </field>
    </record>
    
    <!-- Vue Kanban Réservations -->
    <record id="view_reservation_kanban" model="ir.ui.view">
        <field name="name">reservation.kanban</field>
        <field name="model">travel.reservation</field>
        <field name="arch" type="xml">
            <kanban default_group_by="status">
                <field name="name"/>
                <field name="member_id"/>
                <field name="destination_id"/>
                <field name="check_in"/>
                <field name="check_out"/>
                <field name="total_price"/>
                <field name="remaining_to_pay"/>
                <field name="status"/>
                <templates>
                    <t t-name="kanban-box">
                        <div class="oe_kanban_global_click o_kanban_record_has_image_fill">
                            <div class="oe_kanban_details p-3">
                                <strong class="o_kanban_record_title text-primary">
                                    <field name="name"/>
                                </strong>
                                <div class="mt-2">
                                    <field name="member_id"/>
                                </div>
                                <div class="text-muted">
                                    <field name="destination_id"/>
                                </div>
                                <div class="text-muted mt-1">
                                    <field name="check_in"/> → <field name="check_out"/>
                                </div>
                                <div class="mt-3">
                                    <span class="badge bg-primary fs-6">
                                        <field name="total_price" widget="monetary"/>
                                    </span>
                                    <span class="badge bg-danger" t-if="record.remaining_to_pay.raw_value > 0">
                                        <field name="remaining_to_pay" widget="monetary"/>
                                    </span>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>
    
    <!-- Vue Formulaire Réservations - Style Amélioré -->
    <record id="view_reservation_form" model="ir.ui.view">
        <field name="name">reservation.form</field>
        <field name="model">travel.reservation</field>
        <field name="arch" type="xml">
            <form string="Réservation">
                <header>
                    <button name="action_confirm" string="Confirmer" type="object" 
                            class="btn-success" attrs="{'invisible': [('status', '!=', 'draft')]}"/>
                    <button name="action_print_quote" string="Imprimer Devis" type="object" 
                            attrs="{'invisible': [('status', '!=', 'draft')]}"/>
                    <button name="action_done" string="Terminé" type="object" 
                            class="btn-info" attrs="{'invisible': [('status', '!=', 'confirmed')]}"/>
                    <button name="action_cancel" string="Annuler" type="object" 
                            attrs="{'invisible': [('status', '!=', 'draft')]}"/>
                    <button name="action_create_invoice" type="object" string="Facturer" 
                            class="btn-primary" attrs="{'invisible': [('status', '=', 'draft')]}"/>
                    <button name="action_open_pos" type="object" string="Payer Caisse" 
                            class="btn-warning" attrs="{'invisible': [('remaining_to_pay', '&lt;=', 0)]}"/>
                    <button name="action_open_credit_refund" type="object" string="Avoir" 
                            class="btn-secondary" attrs="{'invisible': [('status', '=', 'draft')]}"/>
                    <button name="action_cancel_and_credit" type="object" string="Annuler &amp; Créditer" 
                            class="btn-danger" attrs="{'invisible': [('status', '!=', 'confirmed')]}" 
                            confirm="Êtes-vous sûr de vouloir annuler cette réservation et créditer le client ?"/>
                    <field name="status" widget="statusbar" statusbar_visible="draft,confirmed,done" options="{'clickable': '1'}"/>
                </header>
                <sheet>
                    <field name="currency_id" invisible="1"/>
                    
                    <!-- Boutons statistiques -->
                    <div class="oe_button_box" name="button_box">
                        <button class="oe_stat_button" type="object" name="action_view_invoices" 
                                icon="fa-file-pdf-o" attrs="{'invisible': [('invoice_count', '=', 0)]}">
                            <field name="invoice_count" widget="statinfo" string="Factures"/>
                        </button>
                        <button class="oe_stat_button" type="object" name="action_view_cash_operations" 
                                icon="fa-money" attrs="{'invisible': [('cash_operation_count', '=', 0)]}">
                            <field name="cash_operation_count" widget="statinfo" string="Paiements"/>
                        </button>
                    </div>
                    
                    <div class="oe_title">
                        <h1>
                            <field name="name" readonly="1"/>
                        </h1>
                    </div>
                    
                    <group>
                        <group string="Client &amp; Voyage">
                            <field name="member_id" options="{'no_create': True}"/>
                            <field name="destination_id" options="{'no_create': True}"/>
                            <field name="trip_type"/>
                        </group>
                        <group string="Dates">
                            <field name="check_in"/>
                            <field name="check_out"/>
                            <field name="nights"/>
                        </group>
                    </group>

                    <notebook>
                        <page string="Détails" name="details">
                            <group>
                                <group string="Participants">
                                    <field name="adults"/>
                                    <field name="children"/>
                                    <field name="infants"/>
                                    <field name="participants"/>
                                </group>
                                <group string="Hébergement">
                                    <field name="hotel_service_id" options="{'no_create': True}"/>
                                    <field name="supplier_id" options="{'no_create': True}"/>
                                    <field name="room_type"/>
                                </group>
                            </group>
                        </page>
                        <page string="Finances" name="finance">
                            <group>
                                <group string="Prix">
                                    <field name="price"/>
                                    <field name="purchase_amount"/>
                                    <field name="total_price" class="oe_subtotal_footer_separator"/>
                                </group>
                                <group string="Paiement">
                                    <field name="use_credit"/>
                                    <field name="credit_used" attrs="{'invisible': [('use_credit', '=', False)]}"/>
                                    <field name="remaining_to_pay" class="oe_subtotal_footer_separator" 
                                           decoration-danger="remaining_to_pay > 0"/>
                                </group>
                            </group>
                        </page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids" widget="mail_followers"/>
                    <field name="activity_ids" widget="mail_activity"/>
                    <field name="message_ids" widget="mail_thread"/>
                </div>
            </form>
        </field>
    </record>
    
    <!-- Vue Recherche -->
    <record id="view_reservation_search" model="ir.ui.view">
        <field name="name">reservation.search</field>
        <field name="model">travel.reservation</field>
        <field name="arch" type="xml">
            <search string="Rechercher Réservations">
                <field name="name" string="Référence"/>
                <field name="member_id" string="Client"/>
                <field name="company_id" string="Société"/>
                <field name="destination_id" string="Voyage"/>
                <field name="supplier_id" string="Fournisseur"/>
                <separator/>
                <filter string="Brouillon" name="draft" domain="[('status', '=', 'draft')]"/>
                <filter string="Confirmées" name="confirmed" domain="[('status', '=', 'confirmed')]"/>
                <filter string="Terminées" name="done" domain="[('status', '=', 'done')]"/>
                <filter string="Annulées" name="cancel" domain="[('status', '=', 'cancel')]"/>
                <separator/>
                <filter string="À payer" name="to_pay" domain="[('remaining_to_pay', '>', 0)]"/>
                <filter string="Payées" name="paid" domain="[('remaining_to_pay', '&lt;=', 0)]"/>
                <separator/>
                <group expand="0" string="Grouper Par">
                    <filter string="État" name="group_status" context="{'group_by': 'status'}"/>
                    <filter string="Client" name="group_member" context="{'group_by': 'member_id'}"/>
                    <filter string="Société" name="group_company" context="{'group_by': 'company_id'}"/>
                    <filter string="Voyage" name="group_dest" context="{'group_by': 'destination_id'}"/>
                    <filter string="Fournisseur" name="group_supplier" context="{'group_by': 'supplier_id'}"/>
                    <filter string="Mois Arrivée" name="group_checkin" context="{'group_by': 'check_in:month'}"/>
                </group>
            </search>
        </field>
    </record>
</odoo>
