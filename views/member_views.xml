<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Vue Liste Membres -->
    <record id="view_member_tree" model="ir.ui.view">
        <field name="name">member.tree</field>
        <field name="model">travel.member</field>
        <field name="arch" type="xml">
            <tree string="Membres" decoration-success="credit_balance > 0">
                <field name="name" string="Nom"/>
                <field name="company_id" string="Société"/>
                <field name="matricule" string="Matricule"/>
                <field name="email" string="Email"/>
                <field name="phone" string="Téléphone"/>
                <field name="credit_balance" string="Crédit" widget="monetary" 
                       decoration-success="credit_balance > 0" decoration-bf="credit_balance > 0"/>
                <field name="reservation_count" string="Réservations" optional="show"/>
            </tree>
        </field>
    </record>
    
    <!-- Vue Formulaire Membres -->
    <record id="view_member_form" model="ir.ui.view">
        <field name="name">member.form</field>
        <field name="model">travel.member</field>
        <field name="arch" type="xml">
            <form string="Membre">
                <sheet>
                    <field name="partner_id" invisible="1"/>
                    <field name="currency_id" invisible="1"/>
                    
                    <!-- Boutons intelligents -->
                    <div class="oe_button_box" name="button_box">
                        <button class="oe_stat_button" type="object" name="action_view_payments" icon="fa-money">
                            <div class="o_stat_info">
                                <span class="o_stat_value">
                                    <field name="total_paid" widget="monetary" options="{'currency_field': 'currency_id'}"/>
                                </span>
                                <span class="o_stat_text">Payé</span>
                            </div>
                        </button>
                        <button class="oe_stat_button" type="object" name="action_view_payments" icon="fa-exclamation-triangle" 
                                attrs="{'invisible': [('total_remaining', '&lt;=', 0)]}">
                            <div class="o_stat_info">
                                <span class="o_stat_value text-danger">
                                    <field name="total_remaining" widget="monetary" options="{'currency_field': 'currency_id'}"/>
                                </span>
                                <span class="o_stat_text">À Payer</span>
                            </div>
                        </button>
                    </div>
                    
                    <!-- En-tête -->
                    <div class="oe_title mb-3">
                        <h1>
                            <field name="name" placeholder="Nom du membre" required="1"/>
                        </h1>
                        <field name="company_id" options="{'no_create': True}" placeholder="Société cliente..."/>
                    </div>
                    
                    <group>
                        <group string="Informations">
                            <field name="matricule"/>
                            <field name="email" widget="email"/>
                            <field name="phone" widget="phone"/>
                        </group>
                        <group string="Finances">
                            <field name="credit_balance" widget="monetary" string="Solde Crédit"/>
                        </group>
                    </group>
                    
                    <notebook>
                        <page string="Réservations" name="reservations">
                            <field name="reservation_ids" nolabel="1">
                                <tree>
                                    <field name="name"/>
                                    <field name="destination_id"/>
                                    <field name="check_in"/>
                                    <field name="check_out"/>
                                    <field name="total_price" widget="monetary"/>
                                    <field name="remaining_to_pay" widget="monetary"/>
                                    <field name="status" widget="badge" 
                                           decoration-success="status == 'confirmed'"
                                           decoration-info="status == 'done'"/>
                                </tree>
                            </field>
                        </page>
                        <page string="Historique Crédit" name="credit_history">
                            <field name="credit_history_ids" nolabel="1">
                                <tree>
                                    <field name="date"/>
                                    <field name="type" widget="badge"/>
                                    <field name="amount" widget="monetary" sum="Total"/>
                                    <field name="note"/>
                                </tree>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids" widget="mail_followers"/>
                    <field name="activity_ids" widget="mail_activity"/>
                    <field name="message_ids" widget="mail_thread"/>
                </div>
            </form>
        </field>
    </record>
    
    <!-- Vue Kanban Membres -->
    <record id="view_member_kanban" model="ir.ui.view">
        <field name="name">member.kanban</field>
        <field name="model">travel.member</field>
        <field name="arch" type="xml">
            <kanban>
                <field name="name"/>
                <field name="company_id"/>
                <field name="matricule"/>
                <field name="email"/>
                <field name="phone"/>
                <field name="credit_balance"/>
                <templates>
                    <t t-name="kanban-box">
                        <div class="oe_kanban_global_click o_kanban_record_has_image_fill">
                            <div class="oe_kanban_details p-3">
                                <strong class="o_kanban_record_title fs-5 text-primary">
                                    <field name="name"/>
                                </strong>
                                <div class="text-muted mt-1" t-if="record.company_id.value">
                                    <field name="company_id"/>
                                </div>
                                <div class="mt-1" t-if="record.matricule.value">
                                    <field name="matricule"/>
                                </div>
                                <div t-if="record.phone.value">
                                    <field name="phone"/>
                                </div>
                                <div class="mt-3">
                                    <span class="badge bg-success fs-6">
                                        <field name="credit_balance" widget="monetary"/>
                                    </span>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>
    
    <!-- Vue recherche -->
    <record id="view_member_search" model="ir.ui.view">
        <field name="name">member.search</field>
        <field name="model">travel.member</field>
        <field name="arch" type="xml">
            <search string="Rechercher Membres">
                <field name="name" string="Nom"/>
                <field name="matricule" string="Matricule"/>
                <field name="email" string="Email"/>
                <field name="phone" string="Téléphone"/>
                <field name="company_id" string="Société"/>
                <separator/>
                <filter string="Avec Crédit" name="with_credit" domain="[('credit_history_ids', '!=', False)]"/>
                <filter string="Sans Crédit" name="without_credit" domain="[('credit_history_ids', '=', False)]"/>
                <separator/>
                <group expand="0" string="Grouper Par">
                    <filter string="Société" name="group_company" context="{'group_by': 'company_id'}"/>
                </group>
            </search>
        </field>
    </record>
    
    <!-- Action -->
    <record id="action_member" model="ir.actions.act_window">
        <field name="name">Membres</field>
        <field name="res_model">travel.member</field>
        <field name="view_mode">tree,kanban,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Créer un nouveau membre
            </p>
            <p>
                Gérez les membres de vos sociétés clientes, leur crédit et leurs réservations de voyages.
            </p>
        </field>
    </record>
</odoo>
